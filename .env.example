# Database
DATABASE_URL=postgresql://user:password@localhost:5432/financeflow

# Auth
SECRET_KEY=your-secret-key-here
GEMINI_API_KEY=your-gemini-api-key

# Mono (Nigeria) - optional when USE_MOCK_MONO=true
MONO_SECRET_KEY=test_sk_your_mono_secret_key
MONO_PUBLIC_KEY=test_pk_your_mono_public_key
MONO_ENV=test

# Simulate Mono API with local mock transaction data (no live Mono calls)
USE_MOCK_MONO=true

# Paystack billing
PAYSTACK_SECRET_KEY=sk_test_your_paystack_secret_key
PAYSTACK_PUBLIC_KEY=pk_test_your_paystack_public_key
# Optional: recurring plan codes created in Paystack dashboard (monthly)
# PAYSTACK_PLAN_STARTER=PLN_xxx
# PAYSTACK_PLAN_GROWTH=PLN_yyy
# PAYSTACK_PLAN_BUSINESS=PLN_zzz

# Frontend
FRONTEND_URL=http://localhost:3000
